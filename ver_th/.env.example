# Neurobuild Real v2 environment
# Copy this file to .env, then put your Hugging Face User Access Token below.
# Keep .env private. Do not paste tokens into commits, screenshots, or chats.

USE_HF_LLM=1
HF_TOKEN=

# Hugging Face Inference Providers OpenAI-compatible chat completions router
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions

# Team-specific models. Change only the model names if a provider/model is unavailable.
HF_MODEL_PLANNING=Qwen/Qwen2.5-7B-Instruct
HF_MODEL_LEGAL=Qwen/Qwen2.5-7B-Instruct
HF_MODEL_DESIGN=Qwen/Qwen2.5-7B-Instruct
HF_MODEL_BUDGET=Qwen/Qwen2.5-7B-Instruct
HF_MODEL_ARCHITECTURE=Qwen/Qwen2.5-Coder-7B-Instruct

# Optional Korea Law Open API OC key. Without it, legal RAG uses local seed data.
LAW_OPEN_API_OC=

# Streamlit port
NEUROBUILD_PORT=8502
